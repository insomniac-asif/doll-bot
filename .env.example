# ── Discord ───────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Discord user ID of the server owner Doll reports to (Developer Mode → Copy User ID)
OWNER_ID=

# ── AI (chat) ─────────────────────────────────────────────
MISTRAL_API_KEY=
# Optional backup for tool-calling
DEEPSEEK_API_KEY=

# ── Moderation (free) ─────────────────────────────────────
OPENAI_API_KEY=

# ── Music (yt-dlp + ffmpeg) ───────────────────────────────
# Optional: lets Spotify links resolve to playable sources
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Social live notifications ─────────────────────────────
# Twitch (official API — free, instant). Create an app at dev.twitch.tv
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# YouTube Data API key (official — free with quota)
YOUTUBE_API_KEY=
# TikTok live detection is FREE — uses tiktok-live-connector, no key needed.
# Apify token (optional, kept for future scrapers)
APIFY_TOKEN=
APIFY_TIKTOK_ACTOR=

# ── Optional polish ───────────────────────────────────────
# Last.fm now-playing (greed-style). Free key at last.fm/api
LASTFM_API_KEY=

# ── Bot settings ──────────────────────────────────────────
BOT_NAME=Doll
DEFAULT_PREFIX=!
